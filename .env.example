############################################
# PhotoEvent — Local / DEV (valeurs de test)
############################################

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=remplacez-par-une-cle-secrete-longue-et-aleatoire
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (PostgreSQL recommandé)
DATABASE_URL=postgres://photoevent:photoevent@localhost:5432/photoevent

# Redis / Celery / Channels (en local hors docker, sinon redis://redis:6379/0 dans compose)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Stockage : local | s3 | r2
STORAGE_BACKEND=local

# AWS S3 (mode s3) ou variables communes
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_S3_ADDRESSING_STYLE=virtual

# Cloudflare R2 (mode r2) — endpoint du compte R2
R2_ENDPOINT_URL=

# Paiements FedaPay
FEDAPAY_API_KEY=sk_sandbox_IesaWFI5rAN0WEV7MCCcXozx
FEDAPAY_ENV=sandbox
FEDAPAY_WEBHOOK_SECRET=
# Frontend FedaPay : lib officielle fedapay-reactjs + script checkout.js (CDN), clé pk_sandbox_… alignée sur FEDAPAY_API_KEY
NEXT_PUBLIC_FEDAPAY_PUBLIC_KEY=
NEXT_PUBLIC_FEDAPAY_ENV=sandbox
# Sandbox — paiement mobile sans redirection / tests opérateurs : voir doc FedaPay (ex. numéro de test 64000001, pays selon méthode).
PUBLIC_BACKEND_BASE_URL=http://localhost:8080
PUBLIC_FRONTEND_BASE_URL=http://localhost:3000
# QR album : l’URL encodée est {PUBLIC_QR_ENTRY_BASE_URL ou PUBLIC_FRONTEND_BASE_URL}/{code_evt}/{code_album}/
# Par défaut (sans cette ligne) = PUBLIC_FRONTEND_BASE_URL → ex. http://localhost:3000/ABC123/DEF456/
# Décommentez seulement pour pointer vers une autre entrée (ex. anciens QR via le backend).
# PUBLIC_QR_ENTRY_BASE_URL=http://localhost:8080

# Thème (optionnel en dev)
APP_NAME=Wistiti
COLOR_PRIMARY=
COLOR_SECONDARY=
COLOR_WHITE=

# CORS (origines du navigateur vers l’API)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost

# Next.js
NGINX_PORT=8080
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Images déjà présentes localement (optionnel)
POSTGRES_IMAGE=postgres:15-alpine
REDIS_IMAGE=redis:7-alpine
NGINX_IMAGE=nginx:alpine

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Sentry (off en dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.0

# Email (dev: console backend, laisse vide)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=wara.wara.awadi@gmail.com
EMAIL_HOST_PASSWORD=kmzp_innr_njwj_cxkr
DEFAULT_FROM_EMAIL=wara.wara.awadi@gmail.com


# Backups (dev: optionnel)
BACKUP_BUCKET=s3://photoevent-backups/localhost
AWS_ENDPOINT_URL=https://s3.fr-par.scw.cloud
