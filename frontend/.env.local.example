# URL du backend (sans slash final). Avec Docker + Nginx sur le port 80 de la machine :
NEXT_PUBLIC_API_URL=http://localhost

# Sans Nginx (Daphne exposé sur le host) : ex. http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket (Channels) — alignez sur l’hôte / port exposés
NEXT_PUBLIC_WS_URL=ws://localhost
